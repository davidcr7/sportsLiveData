{
  "manifest_version": 3,
  "name": "直播吧赛事悬浮窗",
  "version": "1.2.1",
  "description": "点击浏览器工具栏图标，切换查看直播吧各类赛程、实时比分和直播入口。",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.zhibo8.com/*",
    "https://bifen4pc.qiumibao.com/*",
    "https://s.qiumibao.com/*",
    "https://api.qiumibao.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "查看直播吧赛程",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
